# =========================================================================
# Plantilla de variables de entorno. Copie este archivo como `.env` y
# complete los valores reales antes de levantar el stack con
# `docker compose up --build`. NUNCA versione el archivo `.env` real.
# =========================================================================

# -------------------------------------------------------------------------
# Configuración general
# -------------------------------------------------------------------------
APP_ENV=production

# -------------------------------------------------------------------------
# Seguridad y JWT
# -------------------------------------------------------------------------
SECRET_KEY=reemplace_esto_con_una_clave_secreta_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -------------------------------------------------------------------------
# Autenticación Federada (Google OAuth2)
# -------------------------------------------------------------------------
GOOGLE_CLIENT_ID=su_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=su_google_client_secret

# -------------------------------------------------------------------------
# Base de Datos PostgreSQL
# -------------------------------------------------------------------------
POSTGRES_USER=potato_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=potato_leaf_db
DATABASE_URL=postgresql+asyncpg://potato_admin:change_me_in_production@db:5432/potato_leaf_db

# -------------------------------------------------------------------------
# Almacenamiento de Objetos (S3 / Cloudflare R2)
# -------------------------------------------------------------------------
S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
S3_BUCKET_NAME=potato-leaf-images
S3_ACCESS_KEY_ID=su_access_key_id
S3_SECRET_ACCESS_KEY=su_secret_access_key
S3_REGION=auto

# -------------------------------------------------------------------------
# Modelo de Machine Learning local
# -------------------------------------------------------------------------
MODEL_PATH=models/efficientnetb0_irish_dataset.keras
METADATA_PATH=models/metadata_metrics.json
MODEL_INPUT_SIZE=224
LAST_CONV_LAYER_NAME=efficientnetb0
CLASS_NAMES=Tizon_Temprano,Tizon_Tardio,Sana

# -------------------------------------------------------------------------
# Proveedores de LLM externos — Capa Unificada LiteLLM
# -------------------------------------------------------------------------
# LiteLLM resuelve las credenciales leyendo automáticamente las variables
# de entorno estándar de cada proveedor. No se requiere ningún SDK
# propietario adicional para añadir nuevos proveedores.
#
# Formato del parámetro ?model= en el endpoint /stream-report:
#   Alias corto : gemini | openai | claude | groq | azure
#   Identificador canónico LiteLLM: gemini/gemini-1.5-pro | groq/llama3-8b
GEMINI_API_KEY=su_gemini_api_key
OPENAI_API_KEY=su_openai_api_key
ANTHROPIC_API_KEY=su_anthropic_api_key
GROQ_API_KEY=su_groq_api_key
AZURE_INFERENCE_ENDPOINT=https://su-recurso.inference.ai.azure.com
AZURE_INFERENCE_CREDENTIAL=su_azure_inference_credential
AZURE_DEPLOYMENT_NAME=gpt-4o-mini

# Modelo de respaldo activado automáticamente si el modelo primario falla.
# Acepta los mismos alias y formatos canónicos que el parámetro ?model=.
DEFAULT_LLM_PROVIDER=gemini

# -------------------------------------------------------------------------
# CORS (Next.js Web + Aplicación Móvil)
# -------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
